# Client-side (Vite exposes anything prefixed VITE_ to the browser bundle — safe to expose)
# Copy this file to .env and fill in your real OAuth client ID from Google Cloud Console.
VITE_GOOGLE_CLIENT_ID=your-client-id-here.apps.googleusercontent.com

# Cloudflare Turnstile site key (public, safe to expose) — create a widget at
# https://dash.cloudflare.com/?to=/:account/turnstile (free). Leave unset to disable
# the CAPTCHA widget entirely (form submits without verification, useful for local dev).
# The value below is Cloudflare's official "always passes" TEST key — replace with your
# real site key before deploying, or spam protection does nothing in production.
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Server-side only — set these via `wrangler pages secret put <NAME>`, never in a committed file:
#   GOOGLE_CLIENT_ID       (same value as VITE_GOOGLE_CLIENT_ID above, used server-side to verify tokens)
#   SESSION_SECRET         (any long random string — signs the session cookie)
#   ADMIN_EMAILS           (comma-separated list of Google account emails allowed to log into /admin)
#   ORDER_FORM_SECRET      (the existing Google Apps Script order-form token)
#   TURNSTILE_SECRET_KEY   (pairs with VITE_TURNSTILE_SITE_KEY above; test secret is
#                           1x0000000000000000000000000000000AA — replace with your real
#                           secret key before deploying)
